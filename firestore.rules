rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == '31choichoi@gmail.com' && request.auth.token.email_verified == true
      );
    }
    
    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'company', 'email', 'phone', 'type', 'content', 'createdAt']) &&
             data.keys().size() == 7 &&
             data.name is string && data.name.size() <= 100 &&
             data.company is string && data.company.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.phone is string && data.phone.size() <= 50 &&
             data.type is string && data.type.size() <= 50 &&
             data.content is string && data.content.size() <= 5000 &&
             data.createdAt == request.time;
    }

    function isValidProductionRequest(data) {
      return data.keys().hasAll(['name', 'industry', 'color', 'q1', 'q2', 'q3', 'q4', 'q5', 'q6a', 'q6b', 'q6c', 'timestamp']) &&
             data.keys().size() == 12 &&
             data.name is string && data.name.size() <= 200 &&
             data.industry is string && data.industry.size() <= 200 &&
             data.color is string && data.color.size() <= 200 &&
             data.q1 is string &&
             data.q2 is string &&
             data.q3 is list &&
             data.q4 is string &&
             data.q5 is string &&
             data.q6a is string &&
             data.q6b is string &&
             data.q6c is string &&
             data.timestamp == request.time;
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(request.resource.data);
      allow read, list, delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow create: if isValidProductionRequest(request.resource.data);
      allow read, list, delete: if isAdmin();
    }
  }
}
