rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == '31choichoi@gmail.com'
      );
    }
    
    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'company', 'email', 'phone', 'type', 'content', 'createdAt']) &&
             data.keys().size() == 7 &&
             data.name is string && data.name.size() <= 100 &&
             data.company is string && data.company.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.phone is string && data.phone.size() <= 50 &&
             data.type is string && data.type.size() <= 50 &&
             data.content is string && data.content.size() <= 5000 &&
             data.createdAt == request.time;
    }

    function isValidProductionRequest(data) {
      return data.keys().hasAll(['name', 'industry', 'info', 'q1', 'q2', 'q3', 'q4', 'q5', 'q6_color', 'q6a', 'q6b', 'q6c', 'timestamp']) &&
             data.name is string && data.name.size() <= 200 &&
             data.industry is string && data.industry.size() <= 200 &&
             data.info is string && data.info.size() <= 500 &&
             data.q3 is list &&
             data.q6_color is list &&
             data.timestamp == request.time;
    }

    function isValidPortfolio(data) {
      return data.keys().hasAll(['title', 'imageUrl', 'category', 'createdAt', 'link', 'subtitle', 'isPinned']) &&
             data.title is string && data.title.size() <= 200 &&
             data.imageUrl is string && data.imageUrl.size() <= 1000 &&
             data.category in ['commercial', 'brand', 'platform'] &&
             data.link is string && data.link.size() <= 1000 &&
             data.subtitle is string && data.subtitle.size() <= 1000 &&
             data.isPinned is bool;
    }

    function isValidFaq(data) {
       return data.keys().hasAll(['question', 'answer', 'order', 'updatedAt']) &&
              data.question is string && data.question.size() <= 500 &&
              data.answer is string && data.answer.size() <= 5000 &&
              data.order is int;
    }

    function isValidWork(data) {
      return data.keys().hasAll(['title', 'pcImage', 'createdAt', 'tag', 'mobileImage', 'link', 'order']) &&
             data.title is string && data.title.size() <= 200 &&
             data.pcImage is string && data.pcImage.size() <= 1000 &&
             data.mobileImage is string && data.mobileImage.size() <= 1000 &&
             data.tag is string && data.tag.size() <= 100 &&
             data.link is string && data.link.size() <= 1000 &&
             data.order is int;
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(request.resource.data);
      allow read, list, delete: if isAdmin();
      allow update: if isAdmin();
    }

    match /requests/{requestId} {
      allow create: if isValidProductionRequest(request.resource.data);
      allow read, list, delete: if isAdmin();
      allow update: if isAdmin();
    }

    match /portfolio/{itemId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /faqs/{faqId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /works/{workId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
