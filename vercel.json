{
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/portfolio",
      "destination": "/portfolio.html"
    },
    {
      "source": "/service",
      "destination": "/service.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
